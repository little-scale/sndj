# Build output (ROMs, driver blob, generated includes like buildid.inc)
build/

# Emulator cores fetched by tools/emu/ (never committed, per CLAUDE.md §4.3)
tools/emu/cores/

# macOS
.DS_Store

# User-supplied audio is intentionally never distributed with the project.
# Keep local sources and exported factory packs here; the build falls back to
# a deterministic synthesized placeholder factory when none is present.
samples/*
!samples/README.md
soundfonts/*
!soundfonts/README.md
factory/*.sndjfact
!factory/factory.sndjfact
__pycache__/
